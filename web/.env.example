# Copy to .env.local and fill in. Never commit real values.

# --- Postgres (Supabase) ---------------------------------------------------
# Use the Supabase CONNECTION POOLER host (…pooler.supabase.com), NOT the direct
# db host. The PORT decides the pooling mode — this matters a lot on Vercel:
#
#   :6543  transaction mode  ← USE THIS IN PRODUCTION (serverless). A connection
#                              returns to the pool after each query, so many
#                              serverless instances share a few connections.
#   :5432  session mode        Holds one connection for the whole client session.
#                              Fine for a single long-lived process, but on
#                              serverless it exhausts Supabase's 15-client cap
#                              (error: "max clients reached in session mode").
#
# Our queries are all parameterized ($1, $2…) and work in both modes. We don't
# use LISTEN/NOTIFY or cross-transaction prepared statements, so transaction
# mode is fully transparent. Prefer 6543 unless you have a specific reason.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# --- Supabase (public + service) -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- AI + image providers ---------------------------------------------------
ANTHROPIC_API_KEY=<key>   # trip building, insights distillation
PEXELS=<key>              # city posters
UNSPLASH=<key>            # image fallback

# --- Observability (optional) ----------------------------------------------
# Error tracking is INERT until this is set. Create a Sentry project → copy its
# DSN → add here (and in Vercel) to turn on error capture + alerting. Leave
# empty for local dev.
NEXT_PUBLIC_SENTRY_DSN=

# --- AI cost guard (optional overrides, have sane defaults) -----------------
# AI_PER_IP_HOURLY=15     # trip builds per IP per hour
# AI_DAILY_CAP=500        # global daily build ceiling (circuit-breaker)
